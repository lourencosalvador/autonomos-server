# ── Supabase (admin / service role — só no servidor) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (cartão) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_API_VERSION=   # opcional

# ── GPay Angola (Multicaixa Express + Referência) ──
GPAY_BASE_URL=https://pays.gpayangola.com
GPAY_API_KEY=
GPAY_REDIRECT_URL=https://yhanko.com
GPAY_TEST_MODE=true
# GPAY_WEBHOOK_SECRET=  # opcional

# ── Stream (chat) ──
STREAM_API_KEY=
STREAM_API_SECRET=

# ── Twilio (OTP por SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ── Resend (OTP por e-mail) ──
RESEND_API_KEY=

# ── Painel admin de aprovações ──
ADMIN_KEY=troca-por-uma-senha-forte

# ── Ambiente ──
NODE_ENV=production
# PORT é injetado pelo Railway automaticamente — não definir.
